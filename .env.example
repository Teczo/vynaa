# MongoDB Connection String (Required)
# Get this from MongoDB Atlas or local instance
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/vynaa-ai?retryWrites=true&w=majority

# Gemini AI API Key (Required)
# Get this from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# App URL (Optional - defaults to http://localhost:3000)
VITE_APP_URL=http://localhost:3000

# Server Port (Optional - defaults to 3001)
PORT=3001

# Node Environment (Optional - development/production)
NODE_ENV=development
